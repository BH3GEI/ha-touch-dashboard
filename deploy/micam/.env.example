TZ=Asia/Shanghai

# Miloco WebUI listens on http://<colima-lan-ip>:8000 in the bridged Colima VM.
MILOCO_PORT=8000
MILOCO_LOG_LEVEL=warning
MILOCO_BASE_URL=http://127.0.0.1:8000

# Set this to the lowercase MD5 of the Miloco admin password after the WebUI
# password is created. Keep the real value out of git.
MILOCO_PASSWORD=

# Wangwang camera, observed from Home Assistant Xiaomi Home entities.
CAMERA_ID=2115992412
RTSP_URL=rtsp://127.0.0.1:8554/wangwang
VIDEO_CODEC=hevc
STREAM_CHANNEL=0

# Mimi camera. Enable the optional profile only after Miloco can see it online.
CAMERA_2_ID=1212440277
CAMERA_2_RTSP_URL=rtsp://127.0.0.1:8554/mimi
CAMERA_2_VIDEO_CODEC=hevc
CAMERA_2_STREAM_CHANNEL=0

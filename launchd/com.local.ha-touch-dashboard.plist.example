<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.local.ha-virtual-mijia-bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>trap "" PIPE; exec /Users/mac/repos/ha-touch-dashboard/target/release/ha-virtual-mijia-bridge --addr 0.0.0.0:8787 --state /Users/mac/repos/ha-touch-dashboard/state.tsv</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/mac/repos/ha-touch-dashboard</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/mac/repos/ha-touch-dashboard/launchd.out</string>
  <key>StandardErrorPath</key>
  <string>/Users/mac/repos/ha-touch-dashboard/launchd.err</string>
</dict>
</plist>
